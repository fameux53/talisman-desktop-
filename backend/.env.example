# ── Database ──
DATABASE_URL=postgresql+asyncpg://mama:changeme@localhost:5432/talisman

# ── Redis (token blacklisting) ──
# Use fake://localhost for development (in-memory, no Redis needed)
# Use redis://localhost:6379/0 for production
REDIS_URL=fake://localhost

# ── Security ──
# MUST be a strong random string >= 32 chars in production
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false  # Set true in production (requires HTTPS)

# ── CORS ──
# JSON array of allowed origins. Set to your production domain(s).
CORS_ORIGINS=["http://localhost:5173"]

# ── Environment ──
ENVIRONMENT=development  # development | staging | production

# ── SMS (PIN recovery) ──
# stub = logs codes to console (dev only)
# twilio = sends real SMS via Twilio API
SMS_PROVIDER=stub
SMS_GATEWAY_URL=
SMS_API_KEY=

# Twilio credentials (required when SMS_PROVIDER=twilio)
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+1234567890

# ── MonCash (mobile payments, optional) ──
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_IS_SANDBOX=true
MONCASH_CALLBACK_URL=https://your-domain.com/api/v1/payments/moncash/callback

# ── AI Assistant (optional) ──
ANTHROPIC_API_KEY=

# ── Docs access (staging only) ──
DOCS_ACCESS_TOKEN=
